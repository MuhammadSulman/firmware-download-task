{% extends 'base.html.twig' %}

{% block title %}Software Download - CarPlay / Android Auto MMI{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; }

    body {
        margin: 0;
        padding: 0;
        background: #fafafa;
    }

    #software-download {
        font-family: 'Rubik', sans-serif;
        color: #212121;
        text-align: center;
        max-width: 960px;
        margin: 0 auto;
        padding: 20px;
    }

    .card {
        background: #fff;
        padding: 24px;
        border-radius: 4px;
        margin-bottom: 16px;
    }

    .section-title {
        box-shadow: inset 2px 3px 5px #00000040, 2px 3px 5px #00000040;
        border: 1px solid #FFFFFF;
        border-radius: 20px;
        padding: 24px;
        max-width: 590px;
        margin: 0 auto;
        background: #FFFFFF;
    }

    .section-title h1 {
        font-size: 42px;
        line-height: 48px;
        letter-spacing: -0.48px;
        color: #212121;
        font-weight: 300;
        text-align: center;
        margin: 0;
        padding: 0;
    }

    .section-title h1 .bold {
        font-size: 36px;
        letter-spacing: -0.36px;
        font-weight: 700;
    }

    .form-container {
        margin-top: 40px;
    }

    .form-row {
        max-width: 340px;
        margin: 0 auto 12px;
    }

    .form-row label {
        display: block;
        text-align: left;
        font-size: 12px;
        color: #666;
        margin-bottom: 4px;
    }

    .form-row input {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid #E0E0E0;
        border-radius: 4px;
        font-size: 14px;
        line-height: 20px;
        box-shadow: inset 0px 1px 3px #0000001a;
        outline: none;
    }

    .form-row input:focus {
        border-color: #1CA3C2;
    }

    .form-row input:disabled {
        background-color: #f2f2f2;
    }

    .form-row .error-text {
        color: red;
        font-size: 12px;
        margin-top: 2px;
        display: none;
    }

    .btn-check {
        background: linear-gradient(180deg, #1CA3C2 0%, #246574 100%);
        color: #FFFFFF;
        border: none;
        padding: 10px 30px;
        border-radius: 4px;
        font-size: 14px;
        cursor: pointer;
        margin-top: 12px;
    }

    .btn-check:hover {
        background: linear-gradient(190deg, #1CA3C2 0%, #246574 100%);
    }

    .btn-check:disabled {
        opacity: 0.7;
        cursor: default;
    }

    .tooltip-icon {
        display: inline-block;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 1px solid #aaa;
        color: #aaa;
        font-size: 14px;
        line-height: 18px;
        text-align: center;
        cursor: help;
        margin-left: 5px;
        position: relative;
    }

    .tooltip-icon:hover .tooltip-text {
        display: block;
    }

    .tooltip-text {
        display: none;
        position: absolute;
        bottom: 130%;
        left: 50%;
        transform: translateX(-50%);
        width: 250px;
        padding: 10px;
        border-radius: 6px;
        background: #333;
        color: #fff;
        font-size: 12px;
        text-align: center;
        z-index: 10;
    }

    .alert {
        margin-top: 16px;
        padding: 12px 16px;
        border-radius: 4px;
        display: none;
    }

    .alert-success {
        background: #f6ffed;
        border: 1px solid #b7eb8f;
    }

    .alert-success p {
        color: #389e0d;
        margin: 0;
    }

    .alert-error {
        background: #fff2f0;
        border: 1px solid #ffccc7;
    }

    .alert-error p {
        color: red;
        margin: 0;
    }

    .download-link {
        color: #389e0d;
        text-transform: uppercase;
        font-size: 16px;
        text-decoration: underline;
        margin-left: 8px;
    }

    .warning-box {
        margin-top: 16px;
        padding: 16px;
        background: #fffbe6;
        border: 1px solid #ffe58f;
        border-radius: 4px;
        text-align: left;
    }

    .warning-box strong {
        color: #212121;
    }

    .warning-box p {
        color: #212121;
        margin: 8px 0 0;
        font-size: 14px;
    }

    .info-link {
        text-decoration: underline;
        cursor: pointer;
        color: #212121;
        font-size: 14px;
    }

    .btn-shop {
        display: inline-block;
        background: linear-gradient(180deg, #1CA3C2 0%, #246574 100%);
        color: #FFFFFF;
        text-decoration: none;
        padding: 10px 30px;
        border-radius: 4px;
        font-size: 14px;
    }

    .disclaimer {
        margin-top: 12px;
        font-size: 12px;
        color: #666;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-overlay.active {
        display: flex;
    }

    .modal-content {
        background: white;
        max-width: 70%;
        border-radius: 4px;
        overflow: hidden;
        position: relative;
    }

    .modal-header {
        background: black;
        padding: 8px;
        text-align: right;
    }

    .modal-close {
        color: white;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        padding: 4px 8px;
    }

    .modal-content img {
        width: 100%;
        display: block;
    }

    .loading .form-container {
        position: relative;
        pointer-events: none;
    }

    .loading .form-container::before {
        content: "";
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background: rgba(255,255,255,0.8);
        z-index: 100;
    }

    .loading .form-container::after {
        content: "";
        position: absolute;
        top: 50%; left: 50%;
        margin: -1.5em 0 0 -1.5em;
        width: 3em; height: 3em;
        animation: form-spin 0.6s linear infinite;
        border-radius: 500rem;
        border: 0.2em solid;
        border-color: #757575 rgba(0,0,0,0.1) rgba(0,0,0,0.1);
        z-index: 101;
    }

    @keyframes form-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    @media only screen and (max-width: 767px) {
        .section-title { padding: 14px; }
        .section-title h1 { font-size: 35px; line-height: 40px; }
        .section-title h1 .bold { font-size: 27px; line-height: 40px; }
    }
</style>
{% endblock %}

{% block body %}
<div id="software-download">
    <div class="card" id="mainCard">
        <div class="section-title">
            <h1><span class="bold">Update the software for your</span><br>CarPlay / Android Auto MMI</h1>
        </div>

        <form id="softwareForm" class="form-container" onsubmit="return false;">
            <div class="form-row">
                <label for="version">Software Version</label>
                <input type="text" id="version" placeholder="Your software version*" required>
                <div class="error-text" id="versionError">This field is required</div>
            </div>
            <div class="form-row">
                <label for="mcuVersion">MCU Version Not Required</label>
                <input type="text" id="mcuVersion" placeholder="Not Required" disabled>
            </div>
            <div class="form-row">
                <label for="hwVersion">HW Version</label>
                <input type="text" id="hwVersion" placeholder="Your HW version*" required>
                <div class="error-text" id="hwVersionError">This field is required</div>
            </div>

            <div>
                <button type="button" class="btn-check" id="checkBtn" onclick="checkSoftware()">Check</button>
                <span class="tooltip-icon">?
                    <span class="tooltip-text">Enter your current software version to check if there is an update available. You can find your current software in MMI settings > System > System/firmware version.</span>
                </span>
            </div>

            <div class="alert alert-success" id="successAlert">
                <p id="successMsg"></p>
            </div>
            <div class="alert alert-error" id="errorAlert">
                <p id="errorMsg"></p>
            </div>

            <p style="margin-top: 12px;">
                <a class="info-link" onclick="document.getElementById('infoModal').classList.add('active')">What is my current software?</a>
            </p>

            <div class="warning-box">
                <strong>Warning!!!</strong>
                <p>
                    Entering an incorrect software number and uploading it to another version of MMI will brick the MMI.<br>
                    In most cases, this is a reversible process, but impossible to perform without the assistance of our support.<br>
                    BimmerTech is not responsible for errors in software uploading by customers due to uploading the incorrect version.<br>
                    After this step, replacement under warranty cannot be considered.
                </p>
            </div>
        </form>
    </div>

    <div class="card" style="text-align: left;">
        <a class="btn-shop" href="https://newshop.testshop1.bimmer-tech.net/" target="_blank">Go back to the shop</a>
        <p class="disclaimer">
            BMW and MINI are registered trademarks of Bayerische Motoren Werke AG. BimmerTech is not affiliated with BMW AG in any way, and is not authorized by BMW AG to act as an official distributor or representative.
        </p>
    </div>
</div>

<div class="modal-overlay" id="infoModal">
    <div class="modal-content">
        <div class="modal-header">
            <button class="modal-close" onclick="document.getElementById('infoModal').classList.remove('active')">&times;</button>
        </div>
        <div style="padding: 20px; text-align: center; color: #666;">
            <p>Find your software version in:<br><strong>MMI settings &gt; System &gt; System/firmware version</strong></p>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
    document.getElementById('infoModal').addEventListener('click', function(e) {
        if (e.target === this) this.classList.remove('active');
    });

    async function checkSoftware() {
        const version = document.getElementById('version').value.trim();
        const hwVersion = document.getElementById('hwVersion').value.trim();
        const versionError = document.getElementById('versionError');
        const hwVersionError = document.getElementById('hwVersionError');
        const successAlert = document.getElementById('successAlert');
        const errorAlert = document.getElementById('errorAlert');

        versionError.style.display = 'none';
        hwVersionError.style.display = 'none';
        successAlert.style.display = 'none';
        errorAlert.style.display = 'none';

        let valid = true;
        if (!version) {
            versionError.style.display = 'block';
            valid = false;
        }
        if (!hwVersion) {
            hwVersionError.style.display = 'block';
            valid = false;
        }
        if (!valid) return;

        const mainCard = document.getElementById('mainCard');
        mainCard.classList.add('loading');
        document.getElementById('checkBtn').disabled = true;

        try {
            const response = await fetch('{{ path("api_software_version") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    version: version,
                    mcuVersion: document.getElementById('mcuVersion').value,
                    hwVersion: hwVersion
                })
            });

            const data = await response.json();

            if (data.versionExist) {
                let html = data.msg;
                if (data.st) {
                    html += ' <a class="download-link" href="' + data.st + '" target="_blank">ST Version</a>';
                }
                if (data.gd) {
                    html += ' <a class="download-link" href="' + data.gd + '" target="_blank">GD Version</a>';
                }
                document.getElementById('successMsg').innerHTML = html;
                successAlert.style.display = 'block';
            } else if (data.msg) {
                document.getElementById('errorMsg').textContent = data.msg;
                errorAlert.style.display = 'block';
            }
        } catch (err) {
            document.getElementById('errorMsg').textContent = 'Failed to fetch software details. Please try again.';
            errorAlert.style.display = 'block';
        } finally {
            mainCard.classList.remove('loading');
            document.getElementById('checkBtn').disabled = false;
        }
    }
</script>
{% endblock %}
